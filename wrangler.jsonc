{
	// FramePick — FramePick Studio: a Vite/React SPA served as static assets, plus a
	// small Worker that implements /api/generate-image and /api/dop-assist
	// (OpenAI proxy). The Worker runs first for /api/*; everything else is
	// served from ./dist, with SPA fallback to index.html.
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "framepick",
	"main": "worker/index.ts",
	"compatibility_date": "2026-05-30",
	"assets": {
		"directory": "./dist",
		"binding": "ASSETS",
		"run_worker_first": ["/api/*"],
		"not_found_handling": "single-page-application"
	}
}
